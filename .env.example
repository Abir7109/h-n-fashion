# === SUPABASE (Required) ===
# Get these from your Supabase project Dashboard > Settings > API
VITE_SUPABASE_URL="https://your-project-id.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# === Required: Supabase Service Role Key (for Storage uploads) ===
# Get from Supabase Dashboard > Settings > API > service_role key
# This is needed to upload images to Supabase Storage bypassing RLS
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# === ImageKit IO (for product image uploads) ===
# Get these from https://imagekit.io/dashboard/developer/api-keys
IMAGEKIT_PUBLIC_KEY="your_public_key"
IMAGEKIT_PRIVATE_KEY="your_private_key"
IMAGEKIT_URL_ENDPOINT="https://ik.imagekit.io/your_imagekit_id"

# === Product Limits (soft limit - shows count but doesn't block) ===
MAX_IMAGES_PER_PRODUCT=3

# === Site URL (used in production) ===
APP_URL="http://localhost:3000"

# === SMTP Email (for inquiry notifications) ===
# Uses Gmail SMTP by default. For Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password-here"
NOTIFICATION_EMAIL="humayun@handnfashionbd.com"
